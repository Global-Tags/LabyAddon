.window {
    height: 100%;
    width: 100%;

    .input-div {
        margin-top: 10;
    }

    Div {
        height: 35;
        width: fit-content;
        alignment-x: center;

        .label {
            top: 0;
            alignment-x: center;
            font-size: 0.8;
        }
    }

    .preview-div {
        TagPreview {
            top: 0;
            margin-top: 10;
            alignment-x: center;
        }
    }

    .input-div {
        width: 200;

        TextField {
            top: 0;
            margin-top: 10;
            width: 100%;
            alignment-x: center;
        }
    }

    .dropdown-list {
        space-between-entries: 10;
        alignment-x: center;
        margin-top: 20;
        height: 35;
        width: fit-content;

        Div {
            max-width: 200;
        }

        Dropdown {
            top: 0;
            margin-top: 10;
            alignment-x: center;
        }
    }

    .submit-button {
        width: 60;
        margin-top: 20;
        alignment-x: center;
        alignment-y: center;
    }
}